<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.TcmConsultReportAttachmentMapper">

    <resultMap type="TcmConsultReportAttachment" id="TcmConsultReportAttachmentResult">
        <id property="id" column="id" />
        <result property="reportId" column="report_id" />
        <result property="fileType" column="file_type" />
        <result property="fileName" column="file_name" />
        <result property="fileUrl" column="file_url" />
        <result property="fileSize" column="file_size" />
        <result property="remark" column="remark" />
        <result property="createTime" column="create_time" />
    </resultMap>

    <select id="selectTcmConsultReportAttachmentListByReportId" parameterType="Long" resultMap="TcmConsultReportAttachmentResult">
        select id, report_id, file_type, file_name, file_url, file_size, remark, create_time
        from tcm_consult_report_attachment
        where report_id = #{reportId}
        order by id asc
    </select>

    <select id="selectTcmConsultReportAttachmentListByReportIds" resultMap="TcmConsultReportAttachmentResult">
        select id, report_id, file_type, file_name, file_url, file_size, remark, create_time
        from tcm_consult_report_attachment
        where report_id in
        <foreach collection="list" item="reportId" open="(" separator="," close=")">
            #{reportId}
        </foreach>
        order by report_id asc, id asc
    </select>

    <insert id="batchInsertTcmConsultReportAttachment">
        insert into tcm_consult_report_attachment (
            report_id,
            file_type,
            file_name,
            file_url,
            file_size,
            remark,
            create_time
        ) values
        <foreach collection="list" item="item" separator=",">
            (
                #{item.reportId},
                #{item.fileType},
                #{item.fileName},
                #{item.fileUrl},
                #{item.fileSize},
                #{item.remark},
                #{item.createTime}
            )
        </foreach>
    </insert>

    <delete id="deleteTcmConsultReportAttachmentByReportId" parameterType="Long">
        delete from tcm_consult_report_attachment where report_id = #{reportId}
    </delete>
</mapper>
