    item.description = item.introduce;
    item.imgUrl ="/api"+item.coverImage
    return item;
  });
  console.log(allContents.value);
});

let activeTab = ref(type);

const getCurrentContent = computed(() => {
  const keyword = searchKeywords.value[activeTab.value];
  if (!keyword) {
    return allContents.value[activeTab.value];
  }
  return allContents.value[activeTab.value].filter(item => {
    return (
      item.title.includes(keyword) || item.description.includes(keyword)
    );
  });
});

